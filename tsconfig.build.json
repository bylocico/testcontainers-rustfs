{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "Node16",
		"moduleResolution": "Node16",
		"target": "ES2022",
		"types": ["node"],
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*"],
	"exclude": ["test/**/*", "dist/**/*"]
}
